{
  "refresh_interval_ms": 500,
  "icons": {
    "asking":  "exclamationmark.circle",
    "working": "hourglass.circle",
    "waiting": "checkmark.circle",
    "none":    "circle.dotted"
  },
  "header_icons": {
    "asking":  "circle.badge.exclamationmark",
    "working": "hourglass.circle",
    "waiting": "circle.badge.checkmark",
    "none":    "circle.dotted"
  },
  "notify_icons": {
    "asking":  "exclamationmark.circle.fill",
    "working": "hourglass.circle.fill",
    "waiting": "checkmark.circle.fill"
  },
  "action_icons": {
    "open_folder":   "folder.fill",
    "return_to_tab": "apple.terminal.fill",
    "message":       "info.circle"
  },
  "priority": [
    "asking",
    "working",
    "waiting"
  ],
  "claude_events": {
    "SessionStart":     "waiting",
    "UserPromptSubmit": "working",
    "PreToolUse":       "working",
    "PostToolUse":      "working",
    "Notification": {
      "permission_prompt":  "asking",
      "elicitation_dialog": "asking",
      "idle_prompt":        null,
      "auth_success":       null
    },
    "Stop":             "waiting",
    "SubagentStop":     null,
    "PreCompact":       null,
    "SessionEnd":       "end"
  },
  "codex_events": {
    "SessionStart":      "waiting",
    "UserPromptSubmit":  "working",
    "PreToolUse":        "working",
    "PostToolUse":       "working",
    "PermissionRequest": "asking",
    "Stop":              "waiting"
  },
  "notifications": {
    "enabled_states":  [],
    "sound":           false,
    "sound_name":      "Glass",
    "include_summary": true
  }
}
