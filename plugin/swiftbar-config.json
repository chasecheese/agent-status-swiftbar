{
  "refresh_interval_ms": 500,
  "icons": {
    "asking": "bubble.circle.fill",
    "notify": "bell.circle.fill",
    "working": "hourglass.circle.fill",
    "done": "circle.badge.checkmark",
    "idle": "circle",
    "none": "circle.dotted"
  },
  "priority": [
    "asking",
    "notify",
    "working",
    "done",
    "idle"
  ],
  "events": {
    "SessionStart":     "idle",
    "UserPromptSubmit": "working",
    "PreToolUse":       "working",
    "PostToolUse":      "working",
    "Notification": {
      "permission_prompt":  "asking",
      "elicitation_dialog": "asking",
      "idle_prompt":        "notify",
      "auth_success":       "notify"
    },
    "Stop":             "done",
    "SubagentStop":     null,
    "PreCompact":       null,
    "SessionEnd":       "end"
  }
}
